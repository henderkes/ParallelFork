{
    "name": "henderkes/parallel-fork",
    "description": "Fork-based parallel execution via pcntl. Provides Henderkes\\ParallelFork\\run() — full runtime state (services, DB connections) inherited via OS copy-on-write.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-pcntl": "*",
        "ext-posix": "*"
    },
    "suggest": {
        "ext-shmop": "Required for Sync (shared memory)",
        "ext-sysvsem": "Required for Sync (semaphores)",
        "symfony/http-kernel": "For automatic Doctrine/HttpClient reset in Symfony apps (via ParallelForkBundle)",
        "symfony/dependency-injection": "For automatic Doctrine/HttpClient reset in Symfony apps (via ParallelForkBundle)",
        "illuminate/support": "For automatic DB::purge() in Laravel apps (via ParallelForkServiceProvider)"
    },
    "require-dev": {
        "ext-parallel": "*",
        "phpunit/phpunit": "^13.1",
        "doctrine/orm": "^3.7.x-dev",
        "doctrine/dbal": "^4.4",
        "illuminate/database": "^13.4",
        "illuminate/events": "^13.4",
        "symfony/cache": "^7.0",
        "symfony/var-exporter": "^7.0",
        "symfony/framework-bundle": "^6.4 || ^7.0 || ^8.0",
        "phpstan/phpstan": "^2.1",
        "laravel/pint": "^1.29",
        "brlabrussia/parallel-stub": "^1.1"
    },
    "autoload": {
        "psr-4": {
            "Henderkes\\ParallelFork\\": "src/"
        },
        "files": ["src/functions.php"]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "symfony": {
            "bundles": {
                "Henderkes\\ParallelFork\\Symfony\\ParallelForkBundle": ["all"]
            }
        },
        "laravel": {
            "providers": [
                "Henderkes\\ParallelFork\\Laravel\\ParallelForkServiceProvider"
            ]
        }
    }
}
